# Copy this file to .env with `just setup`, then replace the placeholders.
# just loads this file automatically for every recipe.

# Secrets: never commit real values.
TF_VAR_hcloud_token=
TAILSCALE_AUTHKEY=

# Bootstrap access. Restrict SSH to your current public IPv4 address /32.
TF_VAR_ssh_public_key="ssh-ed25519 REPLACE_WITH_YOUR_PUBLIC_KEY you@example.com"
TF_VAR_bootstrap_ssh_source_ips='["203.0.113.10/32"]'

# VPS configuration.
TF_VAR_server_name=agent-vps
TF_VAR_server_type=cx33
TF_VAR_location=nbg1
TF_VAR_image=ubuntu-24.04
TF_VAR_admin_user=admin
TF_VAR_enable_public_ssh=true

# Agent configuration.
AGENT_TIMEZONE=UTC
AGENT_USER=agent
